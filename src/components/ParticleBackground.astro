---
// Ambient particle field — drifting stars with faint connecting lines when
// nearby. Canvas-based, theme-aware, pauses when tab is hidden.
---
<canvas id="particle-bg" aria-hidden="true"></canvas>

<style>
  #particle-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    /* no CSS opacity — we control alpha per-draw call so each theme pops */
  }
</style>

<script>
  function initParticles() {
    const canvas = document.getElementById('particle-bg') as HTMLCanvasElement | null
    if (!canvas) return

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      canvas.style.display = 'none'
      return
    }

    const ctx = canvas.getContext('2d')
    if (!ctx) return

    let W = window.innerWidth
    let H = window.innerHeight
    let dpr = Math.min(window.devicePixelRatio || 1, 2)
    let rafId: number
    let running = true

    function resize() {
      W = window.innerWidth
      H = window.innerHeight
      dpr = Math.min(window.devicePixelRatio || 1, 2)
      canvas!.width  = W * dpr
      canvas!.height = H * dpr
      canvas!.style.width  = W + 'px'
      canvas!.style.height = H + 'px'
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0)
    }
    resize()
    window.addEventListener('resize', resize)

    // ── resolve accent color via canvas (works for ALL CSS color spaces) ──
    let accentR = 100, accentG = 200, accentB = 120
    function sampleAccent() {
      const probe = document.createElement('canvas')
      probe.width = 1; probe.height = 1
      const pc = probe.getContext('2d')!
      pc.fillStyle = getComputedStyle(document.documentElement)
        .getPropertyValue('--theme-accent').trim() || '#4ade80'
      pc.fillRect(0, 0, 1, 1)
      const [r, g, b] = pc.getImageData(0, 0, 1, 1).data
      accentR = r; accentG = g; accentB = b
    }
    sampleAccent()

    // re-sample on theme switch
    const themeObserver = new MutationObserver(sampleAccent)
    themeObserver.observe(document.documentElement, {
      attributes: true, attributeFilter: ['style', 'class', 'data-theme'],
    })

    // ── particles ──────────────────────────────────────────────────────────
    const COUNT = Math.min(65, Math.max(30, Math.floor((W * H) / 18000)))
    const LINK_DIST = Math.min(140, W * 0.12)

    type P = { x: number; y: number; vx: number; vy: number; r: number; pulse: number }
    const particles: P[] = Array.from({ length: COUNT }, () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.22,
      vy: (Math.random() - 0.5) * 0.22,
      r: Math.random() * 1.6 + 0.5,
      pulse: Math.random() * Math.PI * 2,
    }))

    function dot(p: P, a: number) {
      ctx!.beginPath()
      ctx!.arc(p.x, p.y, p.r, 0, Math.PI * 2)
      ctx!.fillStyle = `rgba(${accentR},${accentG},${accentB},${a})`
      ctx!.fill()
    }

    function draw() {
      ctx!.clearRect(0, 0, W, H)

      // move + wrap
      for (const p of particles) {
        p.x += p.vx
        p.y += p.vy
        p.pulse += 0.012
        if (p.x < -10) p.x = W + 10
        if (p.x > W + 10) p.x = -10
        if (p.y < -10) p.y = H + 10
        if (p.y > H + 10) p.y = -10
      }

      // connecting lines
      ctx!.lineWidth = 0.6
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const a = particles[i], b = particles[j]
          const dx = a.x - b.x, dy = a.y - b.y
          const dist = Math.sqrt(dx * dx + dy * dy)
          if (dist < LINK_DIST) {
            const alpha = (1 - dist / LINK_DIST) * 0.18
            ctx!.strokeStyle = `rgba(${accentR},${accentG},${accentB},${alpha})`
            ctx!.beginPath()
            ctx!.moveTo(a.x, a.y)
            ctx!.lineTo(b.x, b.y)
            ctx!.stroke()
          }
        }
      }

      // dots — slightly pulsing alpha
      for (const p of particles) {
        const flicker = (Math.sin(p.pulse) + 1) / 2
        const alpha = 0.30 + flicker * 0.35    // range: 0.30 – 0.65
        dot(p, alpha)
      }

      if (running) rafId = requestAnimationFrame(draw)
    }
    rafId = requestAnimationFrame(draw)

    document.addEventListener('visibilitychange', () => {
      running = !document.hidden
      if (running) rafId = requestAnimationFrame(draw)
      else cancelAnimationFrame(rafId)
    })

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(rafId)
      running = false
      themeObserver.disconnect()
      window.removeEventListener('resize', resize)
    }, { once: true })
  }

  initParticles()
  document.addEventListener('astro:after-swap', initParticles)
</script>
