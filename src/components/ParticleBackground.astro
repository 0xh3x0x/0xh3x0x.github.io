---
// Subtle drifting "stars" background rendered on a single fixed canvas.
// Canvas-based (not DOM nodes) so it stays cheap even with 80+ particles.
// Pauses when the tab is hidden, skips entirely on reduced-motion.
---
<canvas id="particle-bg" aria-hidden="true"></canvas>

<style>
  #particle-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    opacity: 0.55;
  }
</style>

<script>
  function initParticles() {
    const canvas = document.getElementById('particle-bg') as HTMLCanvasElement | null
    if (!canvas) return

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reducedMotion) {
      canvas.remove()
      return
    }

    const ctx = canvas.getContext('2d')
    if (!ctx) return

    let width = window.innerWidth
    let height = window.innerHeight
    let dpr = Math.min(window.devicePixelRatio || 1, 2)
    let rafId: number
    let running = true

    function resize() {
      width = window.innerWidth
      height = window.innerHeight
      dpr = Math.min(window.devicePixelRatio || 1, 2)
      canvas!.width = width * dpr
      canvas!.height = height * dpr
      canvas!.style.width = width + 'px'
      canvas!.style.height = height + 'px'
      ctx!.scale(dpr, dpr)
    }
    resize()

    // particle count scales gently with viewport area, capped for perf
    const COUNT = Math.min(90, Math.max(35, Math.floor((width * height) / 18000)))

    function getAccentRGB(): string {
      const probe = document.createElement('div')
      probe.style.color = 'var(--theme-accent)'
      probe.style.display = 'none'
      document.body.appendChild(probe)
      const rgb = getComputedStyle(probe).color
      probe.remove()
      return rgb
    }
    let accentRGB = getAccentRGB()

    type Star = { x: number; y: number; r: number; vx: number; vy: number; alpha: number; pulse: number }
    const stars: Star[] = Array.from({ length: COUNT }, () => ({
      x: Math.random() * width,
      y: Math.random() * height,
      r: Math.random() * 1.4 + 0.4,
      vx: (Math.random() - 0.5) * 0.08,
      vy: (Math.random() - 0.5) * 0.08,
      alpha: Math.random() * 0.5 + 0.15,
      pulse: Math.random() * Math.PI * 2,
    }))

    function draw() {
      ctx!.clearRect(0, 0, width, height)
      for (const s of stars) {
        s.x += s.vx
        s.y += s.vy
        s.pulse += 0.01

        if (s.x < -5) s.x = width + 5
        if (s.x > width + 5) s.x = -5
        if (s.y < -5) s.y = height + 5
        if (s.y > height + 5) s.y = -5

        const flicker = (Math.sin(s.pulse) + 1) / 2
        const a = s.alpha * (0.6 + flicker * 0.4)

        ctx!.beginPath()
        ctx!.arc(s.x, s.y, s.r, 0, Math.PI * 2)
        ctx!.fillStyle = accentRGB.replace(/rgba?\(([^)]+)\)/, (_m, vals) => {
          const parts = vals.split(',').slice(0, 3).join(',')
          return `rgba(${parts}, ${a})`
        })
        ctx!.fill()
      }
      if (running) rafId = requestAnimationFrame(draw)
    }
    rafId = requestAnimationFrame(draw)

    function onResize() { resize() }
    window.addEventListener('resize', onResize)

    function onVisibility() {
      running = !document.hidden
      if (running) rafId = requestAnimationFrame(draw)
      else cancelAnimationFrame(rafId)
    }
    document.addEventListener('visibilitychange', onVisibility)

    // re-sample accent color if the user switches themes at runtime
    const themeObserver = new MutationObserver(() => { accentRGB = getAccentRGB() })
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['style', 'class', 'data-theme'] })

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(rafId)
      window.removeEventListener('resize', onResize)
      document.removeEventListener('visibilitychange', onVisibility)
      themeObserver.disconnect()
    }, { once: true })
  }

  initParticles()
  document.addEventListener('astro:after-swap', initParticles)
</script>
