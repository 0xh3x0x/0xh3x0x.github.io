---
import type { CollectionEntry } from 'astro:content'
import { render } from 'astro:content'
import { dateString } from '~/utils'

interface Props {
  post: CollectionEntry<'posts'>
}

const { post } = Astro.props
const { remarkPluginFrontmatter } = await render(post)
const description = remarkPluginFrontmatter.description || post.data.description
const minutesRead  = remarkPluginFrontmatter.minutesRead
const articleLink  = `/posts/${post.id}`

const tags = post.data.tags || []
const difficulty = post.data.difficulty
const timeToPwn = post.data.timeToPwn

const difficultyColors: Record<string, string> = {
  Easy:    'text-green-400  border-green-400/30  bg-green-400/8',
  Medium:  'text-yellow-400 border-yellow-400/30 bg-yellow-400/8',
  Hard:    'text-red-400    border-red-400/30    bg-red-400/8',
  Insane:  'text-purple-400 border-purple-400/30 bg-purple-400/8',
  Unknown: 'text-foreground/40 border-foreground/15 bg-foreground/5',
}

const osTag = post.data.osType
const osClass = osTag === 'Windows'
  ? 'text-blue-400 border-blue-400/30 bg-blue-400/8'
  : osTag === 'Linux'
    ? 'text-orange-400 border-orange-400/30 bg-orange-400/8'
    : ''

const techTags = tags.filter((t: string) => !['HTB','PortSwigger'].includes(t)).slice(0, 3)
---

<a
  href={articleLink}
  class="group flex flex-col gap-1.5 p-4 rounded-lg border-1 border-accent/10 bg-accent/2 hover:bg-accent/6 hover:border-accent/25 transition-all duration-200"
>
  <div class="flex items-start justify-between gap-2">
    <span
      class="glitch-title font-semibold text-heading1 text-base group-hover:text-accent transition-colors leading-snug line-clamp-2"
      data-text={post.data.title}
    >
      {post.data.title}
    </span>
    <span class="shrink-0 text-xs text-foreground/50 mt-0.5 font-mono whitespace-nowrap">
      {dateString(post.data.published)}
    </span>
  </div>

  {description && (
    <p class="text-sm text-foreground/65 line-clamp-2 leading-relaxed">{description}</p>
  )}

  <div class="flex flex-wrap items-center gap-1.5 mt-0.5">
    {difficulty && (
      <span class:list={['text-xs font-mono px-2 py-0.5 rounded-full border-1', difficultyColors[difficulty] || 'text-foreground/50 border-foreground/15']}>
        {difficulty}
      </span>
    )}
    {osTag && (
      <span class:list={['text-xs font-mono px-2 py-0.5 rounded-full border-1', osClass]}>
        {osTag}
      </span>
    )}
    {techTags.map((tag: string) => (
      <span class="text-xs font-mono px-2 py-0.5 rounded-full border-1 border-accent/15 text-accent/60 bg-accent/3">
        {tag}
      </span>
    ))}

    {/* Time to pwn / reading time */}
    <span class="ml-auto text-xs font-mono text-foreground/35 flex items-center gap-1 shrink-0">
      <span class="text-accent/40">⏱</span>
      {timeToPwn ? `~${timeToPwn}` : minutesRead || ''}
    </span>
  </div>
</a>

<style>
  .glitch-title {
    position: relative;
    display: block;
  }
  .glitch-title::before,
  .glitch-title::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    overflow: hidden;
    background: var(--theme-background);
  }
  .glitch-title::before {
    color: #ff3b6b;
    clip-path: inset(0 0 0 0);
  }
  .glitch-title::after {
    color: #3bdfff;
    clip-path: inset(0 0 0 0);
  }

  .group:hover .glitch-title::before {
    opacity: 0.7;
    animation: glitch-shift-1 0.35s steps(2, end) 1;
  }
  .group:hover .glitch-title::after {
    opacity: 0.7;
    animation: glitch-shift-2 0.35s steps(2, end) 1;
  }

  @keyframes glitch-shift-1 {
    0%   { transform: translate(0, 0);     clip-path: inset(0 0 80% 0); }
    20%  { transform: translate(-2px, 1px); clip-path: inset(10% 0 60% 0); }
    40%  { transform: translate(2px, -1px); clip-path: inset(40% 0 30% 0); }
    60%  { transform: translate(-1px, 1px); clip-path: inset(60% 0 10% 0); }
    80%  { transform: translate(1px, 0);    clip-path: inset(80% 0 0 0); }
    100% { transform: translate(0, 0); opacity: 0; }
  }
  @keyframes glitch-shift-2 {
    0%   { transform: translate(0, 0);      clip-path: inset(80% 0 0 0); }
    20%  { transform: translate(2px, -1px); clip-path: inset(60% 0 10% 0); }
    40%  { transform: translate(-2px, 1px); clip-path: inset(30% 0 40% 0); }
    60%  { transform: translate(1px, -1px); clip-path: inset(10% 0 60% 0); }
    80%  { transform: translate(-1px, 0);   clip-path: inset(0 0 80% 0); }
    100% { transform: translate(0, 0); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch-title::before,
    .glitch-title::after { display: none; }
  }
</style>
