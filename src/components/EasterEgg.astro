---
// Easter egg: type "sudo" anywhere on the site (no input focused) to pop a
// fake root shell overlay. Press Escape or click outside to close.
---
<div id="easter-egg-overlay" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/70 backdrop-blur-sm p-4" role="dialog" aria-modal="true" aria-label="Easter egg terminal">
  <div class="w-full max-w-lg rounded-xl border-1 border-green-400/30 bg-[#0a0a0a] overflow-hidden shadow-2xl font-mono" style="box-shadow: 0 0 40px rgba(74, 222, 128, 0.15)">
    <div class="flex items-center gap-2 px-4 py-2.5 border-b-1 border-green-400/15 bg-green-400/5">
      <span class="size-3 rounded-full bg-red-400/60"></span>
      <span class="size-3 rounded-full bg-yellow-400/60"></span>
      <span class="size-3 rounded-full bg-green-400/60"></span>
      <span class="ml-3 text-xs text-green-400/50 tracking-widest">root@0xh3x_:~#</span>
      <button id="egg-close" class="ml-auto text-green-400/40 hover:text-green-400 text-xs" aria-label="Close">[x]</button>
    </div>
    <div class="p-5 text-sm text-green-400/90 leading-relaxed">
      <div id="egg-output"></div>
      <div class="flex gap-1 mt-1">
        <span class="text-green-400">$</span>
        <span id="egg-cursor" class="inline-block w-2 h-4 bg-green-400/80 animate-pulse"></span>
      </div>
    </div>
  </div>
</div>

<script>
  function initEasterEgg() {
    const overlay = document.getElementById('easter-egg-overlay')
    const output = document.getElementById('egg-output')
    const closeBtn = document.getElementById('egg-close')
    if (!overlay || !output) return

    const SECRET = 'sudo'
    let buffer = ''

    const lines = [
      'Password: ********',
      'Access granted.',
      '',
      'Welcome back, operator.',
      'Permissions: root',
      'Uptime: forever',
      '',
      'You found the easter egg. Nothing dangerous here —',
      'just a fellow hacker who likes a good Easter egg.',
      '',
      "Press 'Escape' or click [x] to exit this session.",
    ]

    function typeLines() {
      output!.innerHTML = ''
      let li = 0
      function nextLine() {
        if (li >= lines.length) return
        const div = document.createElement('div')
        div.textContent = lines[li]
        div.style.minHeight = '1.2em'
        output!.appendChild(div)
        li++
        setTimeout(nextLine, 120)
      }
      nextLine()
    }

    function openEgg() {
      overlay!.classList.remove('hidden')
      overlay!.classList.add('flex')
      typeLines()
    }
    function closeEgg() {
      overlay!.classList.add('hidden')
      overlay!.classList.remove('flex')
      buffer = ''
    }

    document.addEventListener('keydown', (e) => {
      // ignore when typing in inputs/textareas or when overlay is open
      const tag = (document.activeElement?.tagName || '').toLowerCase()
      if (tag === 'input' || tag === 'textarea') return

      if (!overlay!.classList.contains('hidden')) {
        if (e.key === 'Escape') closeEgg()
        return
      }

      if (e.key.length === 1) {
        buffer = (buffer + e.key).slice(-SECRET.length)
        if (buffer.toLowerCase() === SECRET) {
          buffer = ''
          openEgg()
        }
      }
    })

    closeBtn?.addEventListener('click', closeEgg)
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) closeEgg()
    })
  }

  initEasterEgg()
  document.addEventListener('astro:after-swap', initEasterEgg)
</script>
