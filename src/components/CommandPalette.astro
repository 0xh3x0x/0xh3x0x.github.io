---
// Lightweight navigation command palette. Bound to Ctrl+/ (Cmd+/ on Mac) —
// deliberately NOT Ctrl+K, since that's already used by the Pagefind search
// component. This palette is for jumping to pages/sections, not full-text
// content search.

const commands = [
  { label: 'Home', hint: 'go to homepage', href: '/', icon: '⌂' },
  { label: 'About', hint: 'operator profile', href: '/about', icon: '◇' },
  { label: 'Archive — All Posts', hint: 'every writeup', href: '/posts#all', icon: '◈' },
  { label: 'Archive — HTB', hint: 'Hack The Box machines', href: '/posts#htb', icon: '⬡' },
  { label: 'Archive — PortSwigger', hint: 'web security labs', href: '/posts#portswigger', icon: '⬢' },
  { label: 'Archive — Blog', hint: 'general posts', href: '/posts#blog', icon: '◆' },
  { label: 'Stats', hint: 'charts & breakdowns', href: '/stats', icon: '📊' },
  { label: 'GitHub', hint: 'open profile', href: 'https://github.com/0xh3x0x', icon: '↗', external: true },
]
---

<div id="cmdk-overlay" class="fixed inset-0 z-[9999] hidden items-start justify-center bg-black/60 backdrop-blur-sm p-4 pt-20 sm:pt-32" role="dialog" aria-modal="true" aria-label="Command palette">
  <div class="w-full max-w-md rounded-xl border-1 border-accent/25 bg-background shadow-2xl overflow-hidden font-mono" style="box-shadow: 0 0 40px color-mix(in srgb, var(--theme-accent), 12%, transparent)">
    <div class="flex items-center gap-2 px-4 py-3 border-b-1 border-accent/15">
      <span class="text-accent/50 text-sm">$</span>
      <input
        id="cmdk-input"
        type="text"
        placeholder="jump to..."
        autocomplete="off"
        class="flex-1 bg-transparent border-none outline-none text-sm text-foreground placeholder:text-foreground/30"
      />
      <kbd class="text-xs text-foreground/30 border-1 border-accent/15 rounded px-1.5 py-0.5">esc</kbd>
    </div>
    <div id="cmdk-list" class="max-h-80 overflow-y-auto py-2"></div>
    <div class="px-4 py-2 border-t-1 border-accent/10 text-xs text-foreground/30 flex items-center gap-3">
      <span class="flex items-center gap-1"><kbd class="border-1 border-accent/15 rounded px-1">↑↓</kbd> navigate</span>
      <span class="flex items-center gap-1"><kbd class="border-1 border-accent/15 rounded px-1">↵</kbd> select</span>
    </div>
  </div>
</div>

<script define:vars={{ commands }}>
  function initCmdK() {
    const overlay = document.getElementById('cmdk-overlay')
    const input = document.getElementById('cmdk-input')
    const list = document.getElementById('cmdk-list')
    if (!overlay || !input || !list) return

    let activeIndex = 0
    let filtered = commands

    function render() {
      list.innerHTML = ''
      if (filtered.length === 0) {
        list.innerHTML = '<div class="px-4 py-6 text-center text-xs text-foreground/30 font-mono">// no matches</div>'
        return
      }
      filtered.forEach((cmd, i) => {
        const row = document.createElement('a')
        row.href = cmd.href
        if (cmd.external) { row.target = '_blank'; row.rel = 'noopener noreferrer' }
        row.className = 'cmdk-row flex items-center gap-3 px-4 py-2.5 cursor-pointer text-sm transition-colors' + (i === activeIndex ? ' cmdk-active' : '')
        row.innerHTML = `
          <span class="text-accent/70 w-5 text-center shrink-0">${cmd.icon}</span>
          <span class="flex-1 min-w-0">
            <span class="text-foreground/85 block truncate">${cmd.label}</span>
            <span class="text-foreground/35 text-xs block truncate">${cmd.hint}</span>
          </span>
          ${cmd.external ? '<span class="text-foreground/25 text-xs shrink-0">↗</span>' : ''}
        `
        row.addEventListener('mouseenter', () => { activeIndex = i; render() })
        row.addEventListener('click', () => closePalette())
        list.appendChild(row)
      })
    }

    function openPalette() {
      overlay.classList.remove('hidden')
      overlay.classList.add('flex')
      input.value = ''
      filtered = commands
      activeIndex = 0
      render()
      setTimeout(() => input.focus(), 10)
    }

    function closePalette() {
      overlay.classList.add('hidden')
      overlay.classList.remove('flex')
    }

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim()
      filtered = !q
        ? commands
        : commands.filter(c => c.label.toLowerCase().includes(q) || c.hint.toLowerCase().includes(q))
      activeIndex = 0
      render()
    })

    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault()
        activeIndex = Math.min(activeIndex + 1, filtered.length - 1)
        render()
      } else if (e.key === 'ArrowUp') {
        e.preventDefault()
        activeIndex = Math.max(activeIndex - 1, 0)
        render()
      } else if (e.key === 'Enter') {
        e.preventDefault()
        const cmd = filtered[activeIndex]
        if (cmd) {
          if (cmd.external) window.open(cmd.href, '_blank', 'noopener,noreferrer')
          else window.location.href = cmd.href
          closePalette()
        }
      } else if (e.key === 'Escape') {
        closePalette()
      }
    })

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closePalette()
    })

    // global shortcut: Ctrl+/ or Cmd+/
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === '/') {
        e.preventDefault()
        if (overlay.classList.contains('hidden')) openPalette()
        else closePalette()
      }
    })

    // one-time discoverability hint, shown briefly on first visit per browser
    if (!sessionStorage.getItem('cmdk-hint-shown')) {
      sessionStorage.setItem('cmdk-hint-shown', '1')
      const hint = document.createElement('div')
      hint.className = 'cmdk-hint'
      hint.innerHTML = 'Press <kbd>Ctrl</kbd> + <kbd>/</kbd> to jump anywhere'
      document.body.appendChild(hint)
      setTimeout(() => hint.classList.add('cmdk-hint-visible'), 600)
      setTimeout(() => {
        hint.classList.remove('cmdk-hint-visible')
        setTimeout(() => hint.remove(), 400)
      }, 5000)
    }
  }

  initCmdK()
  document.addEventListener('astro:after-swap', initCmdK)
</script>

<style>
  .cmdk-active {
    background: color-mix(in srgb, var(--theme-accent), 10%, transparent);
  }
  #cmdk-list a:hover {
    background: color-mix(in srgb, var(--theme-accent), 8%, transparent);
  }
</style>

<style is:global>
  .cmdk-hint {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 9997;
    background: var(--theme-background);
    border: 1px solid color-mix(in srgb, var(--theme-accent), 25%, transparent);
    color: color-mix(in srgb, var(--theme-foreground), 35%, transparent);
    font-family: var(--theme-font), monospace;
    font-size: 0.75rem;
    padding: 0.5rem 0.85rem;
    border-radius: 0.6rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }
  .cmdk-hint-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .cmdk-hint kbd {
    border: 1px solid color-mix(in srgb, var(--theme-accent), 20%, transparent);
    border-radius: 0.3rem;
    padding: 0.05rem 0.35rem;
    color: var(--theme-accent);
    font-size: 0.7rem;
  }
</style>
