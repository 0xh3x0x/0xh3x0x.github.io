---
// Listens for clicks on Expressive Code's built-in copy button and shows a
// terminal-style "[+] copied to clipboard" toast. Does not replace EC's own
// copy logic or icon swap — purely additive, so it keeps working even if
// the underlying library changes its internals.
---
<div id="copy-toast" role="status" aria-live="polite"></div>

<style>
  #copy-toast {
    position: fixed;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%) translateY(12px);
    z-index: 9996;
    background: var(--theme-background);
    border: 1px solid color-mix(in srgb, var(--theme-accent), 35%, transparent);
    color: var(--theme-accent);
    font-family: var(--theme-font), monospace;
    font-size: 0.8rem;
    padding: 0.55rem 1rem;
    border-radius: 0.6rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
    box-shadow: 0 0 24px color-mix(in srgb, var(--theme-accent), 15%, transparent);
    white-space: nowrap;
  }
  #copy-toast.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<script>
  function initCopyToast() {
    const toast = document.getElementById('copy-toast')
    if (!toast) return

    const MESSAGES = [
      '[+] copied to clipboard',
      '[+] payload copied',
      '[+] snippet exfiltrated to clipboard',
      '[+] copy successful — go forth and pwn',
    ]

    let hideTimer: ReturnType<typeof setTimeout> | null = null

    function showToast() {
      const msg = MESSAGES[Math.floor(Math.random() * MESSAGES.length)]
      toast!.textContent = msg
      toast!.classList.add('visible')
      if (hideTimer) clearTimeout(hideTimer)
      hideTimer = setTimeout(() => toast!.classList.remove('visible'), 1800)
    }

    // Expressive Code renders: <div class="expressive-code"> ... <button class="copy">
    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement)?.closest('.expressive-code button.copy, figure.frame button.copy')
      if (btn) showToast()
    })
  }

  initCopyToast()
  document.addEventListener('astro:after-swap', initCopyToast)
</script>
